{
  "name": "bulwark-plugin-template",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.js --bundle --format=cjs --platform=neutral --outfile=dist/index.js --external:react --external:react-dom --external:react-dom/client --external:react/jsx-runtime",
    "zip": "node -e \"const{execSync}=require('child_process');execSync('cd dist && zip -X ../my-plugin.zip manifest.json index.js',{stdio:'inherit'})\"",
    "package": "npm run build && cp manifest.json dist/ && cd dist && zip -X ../my-plugin.zip manifest.json index.js"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  }
}
